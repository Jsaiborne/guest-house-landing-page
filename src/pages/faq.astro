---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frequently Asked Questions | Romillie Hadeljo">
  <div class="bg-emerald-950 min-h-screen text-stone-200">
    <main class="pt-32 pb-20 px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-8 border-b border-white/10 pb-6">Frequently Asked Questions</h1>
        
        <p class="text-emerald-200/60 mb-12 text-lg">Everything you need to know about your stay at Romillie Hadeljo.</p>

        <div class="space-y-8">
          <!-- Arrival & Departure -->
          <section>
            <h2 class="text-xl font-serif text-emerald-400 mb-6 uppercase tracking-widest text-sm">Arrival & Departure</h2>
            <div class="space-y-4">
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">What are the check-in and check-out times?</h3>
                <p class="text-stone-400 leading-relaxed">Check-in is from 2:00 PM onwards, and check-out is by 11:00 AM. If you require early check-in or late check-out, please let us know in advance, and we will do our best to accommodate you based on availability.</p>
              </div>
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">Do you offer luggage storage?</h3>
                <p class="text-stone-400 leading-relaxed">Yes, we can securely store your luggage if you arrive before check-in or wish to explore the city after checking out.</p>
              </div>
            </div>
          </section>

          <!-- Policies -->
          <section>
            <h2 class="text-xl font-serif text-emerald-400 mb-6 uppercase tracking-widest text-sm">Policies</h2>
            <div class="space-y-4">
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">What is your cancellation policy?</h3>
                <p class="text-stone-400 leading-relaxed">Cancellations made up to 7 days before the arrival date will receive a full refund. Cancellations made within 7 days of arrival are subject to a one-night charge. Specific peak-season policies may vary.</p>
              </div>
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">Are pets allowed?</h3>
                <p class="text-stone-400 leading-relaxed">While we love animals, we currently maintain a no-pet policy to ensure the comfort and allergy-safety of all our guests. We can, however, recommend local boarding services if needed.</p>
              </div>
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">Is smoking permitted?</h3>
                <p class="text-stone-400 leading-relaxed">Romillie Hadeljo is a non-smoking property. Smoking is strictly prohibited inside the rooms and common indoor areas. Designated outdoor smoking areas are available.</p>
              </div>
            </div>
          </section>

          <!-- Amenities & Services -->
          <section>
            <h2 class="text-xl font-serif text-emerald-400 mb-6 uppercase tracking-widest text-sm">Amenities & Services</h2>
            <div class="space-y-4">
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">Is breakfast included?</h3>
                <p class="text-stone-400 leading-relaxed">Yes, a complimentary traditional breakfast is served daily for all our guests in the dining area.</p>
              </div>
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">Do you have on-site parking?</h3>
                <p class="text-stone-400 leading-relaxed">Yes, we provide free private parking for our guests. No prior reservation for parking is required.</p>
              </div>
              <div class="bg-white/5 border border-white/10 p-6 rounded-sm">
                <h3 class="text-white font-medium mb-2">Is there Wi-Fi available?</h3>
                <p class="text-stone-400 leading-relaxed">High-speed Wi-Fi is available throughout the property, including all guest rooms and common areas, free of charge.</p>
              </div>
            </div>
          </section>
        </div>

        <div class="mt-16 p-8 bg-emerald-900/30 border border-emerald-500/20 rounded-sm text-center">
          <h2 class="text-2xl font-serif text-white mb-4">Still have questions?</h2>
          <p class="text-stone-300 mb-6">We're here to help you plan your perfect stay.</p>
          <a href="/#contact" class="inline-block bg-white text-emerald-950 px-8 py-3 rounded-sm font-medium hover:bg-stone-100 transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </main>
  </div>
</Layout>
