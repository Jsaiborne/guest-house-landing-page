---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rules & Regulations | Romillie Hadeljo">
  <div class="bg-emerald-950 min-h-screen text-stone-200">
    <main class="pt-32 pb-20 px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-serif text-white mb-8 border-b border-white/10 pb-6">House Rules</h1>
        
        <p class="text-emerald-200/60 mb-12 text-lg italic">To ensure a comfortable, safe, and pleasant stay for all our guests, please adhere to the following policies during your stay at Romillie Hadeljo.</p>

        <div class="space-y-12">
          <!-- Must Read Rules -->
          <section class="bg-white/5 border border-white/10 p-8 rounded-xl">
            <h2 class="text-2xl font-serif text-emerald-400 mb-6 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-400"></span> Must Read Rules
            </h2>
            <ul class="list-disc pl-6 text-stone-300 space-y-4">
              <li class="leading-relaxed"><strong>Primary Guest Age:</strong> The primary guest checking in must be at least 18 years of age.</li>
              <li class="leading-relaxed"><strong>Guest Profile:</strong> Groups with only male guests are welcome at the property. However, unmarried couples are strictly not allowed.</li>
              <li class="leading-relaxed"><strong>Smoking & Alcohol:</strong> Both smoking and alcohol consumption are strictly prohibited anywhere within the property premises.</li>
            </ul>
          </section>

          <!-- Identification Policies -->
          <section>
            <h2 class="text-2xl font-serif text-emerald-400 mb-4">ID Proof Requirements</h2>
            <p class="text-stone-300 leading-relaxed mb-4">
              Passport, Aadhaar, and Driving License are accepted as valid ID proof(s) upon check-in. Local IDs are allowed.
            </p>
          </section>

          <!-- Accessibility -->
          <section class="border-l-4 border-amber-500/50 pl-6 py-2 bg-amber-500/5 rounded-r-xl">
            <h2 class="text-2xl font-serif text-amber-300 mb-3">Property Accessibility</h2>
            <p class="text-stone-300 leading-relaxed">
              Please note that this property is <strong>not accessible</strong> to guests who use a wheelchair. Please make your travel arrangements accordingly.
            </p>
          </section>

          <!-- Check-in & Key Handover -->
          <section>
            <h2 class="text-2xl font-serif text-emerald-400 mb-4">Check-in & Key Pickup</h2>
            <p class="text-stone-300 leading-relaxed mb-4">
              Upon arrival, the Host or Caretaker will personally greet you and help you check-in. Guests can collect or deposit keys through the building staff.
            </p>
            <p class="text-stone-400 leading-relaxed text-sm italic">
              * Note: Self check-in via Smart Door is not available at this property.
            </p>
          </section>
        </div>

        <div class="mt-16 text-center text-emerald-200/40 text-sm italic">
          <p>Thank you for your cooperation and for choosing Romillie Hadeljo.</p>
        </div>
      </div>
    </main>
  </div>
</Layout>
