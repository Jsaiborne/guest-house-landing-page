---
import InquiryForm from './InquiryForm.astro';
---

<section id="contact" class="py-32 px-6 bg-emerald-950 text-center relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-emerald-900 rounded-full blur-3xl opacity-50 pointer-events-none"></div>

  <div class="max-w-4xl mx-auto relative z-10">
    <h2 class="text-4xl md:text-5xl font-serif text-white mb-6">Plan Your Serene Getaway</h2>
    <p class="text-emerald-100 mb-12 text-lg md:text-xl font-light max-w-2xl mx-auto">
      For the easiest booking process and a completely hassle-free experience, we highly encourage you to book directly through our official 
      <a href="https://www.makemytrip.com/hotels/romillie_hadeljo-details-shillong.html" target="_blank" rel="noopener noreferrer" class="underline hover:text-emerald-300 font-medium transition-colors">MakeMyTrip</a> or 
      <a href="https://www.goibibo.com/hotels/romillie-hadeljo-hotel-in-shillong-4032960575066252791/" target="_blank" rel="noopener noreferrer" class="underline hover:text-emerald-300 font-medium transition-colors">Goibibo</a> pages. Alternatively, send an inquiry below or reach out via WhatsApp/Email.
    </p>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <div class="lg:col-span-2">
        <InquiryForm />
      </div>

      <div class="space-y-6 lg:pt-0">
        <div class="bg-white/5 backdrop-blur-sm p-8 rounded-sm border border-white/10 text-left">
          <h3 class="text-white font-serif text-xl mb-6">Quick Contact</h3>
          
          <div class="space-y-4">
            <a 
              href="https://wa.me/919856030532" 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-full bg-[#25D366] text-white px-6 py-4 rounded-sm font-medium hover:bg-[#20bd5a] hover:-translate-y-1 transition-all duration-300 shadow-lg flex items-center justify-center gap-3"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              WhatsApp
            </a>
            
            <a 
              href="mailto:bahehdowski@gmail.com" 
              class="w-full bg-white text-emerald-950 px-6 py-4 rounded-sm font-medium hover:bg-stone-100 hover:-translate-y-1 transition-all duration-300 shadow-lg flex items-center justify-center gap-3"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Email Us
            </a>
          </div>

          <div class="mt-6 pt-6 border-t border-white/10 space-y-3">
            <p class="text-xs uppercase tracking-widest text-emerald-400 font-semibold mb-2">Call Us Directly</p>
            <a href="tel:+919856030532" class="block text-sm text-stone-200 hover:text-white transition-colors">
              📞 +91 98560 30532 <span class="text-[10px] text-emerald-400 font-medium ml-1">(Primary)</span>
            </a>
            <a href="tel:+919089752395" class="block text-sm text-stone-200 hover:text-white transition-colors">
              📞 +91 90897 52395 <span class="text-[10px] text-emerald-400 font-medium ml-1">(Secondary)</span>
            </a>
            <a href="tel:+918014991517" class="block text-sm text-stone-200 hover:text-white transition-colors">
              📞 +91 80149 91517
            </a>
          </div>

          <div class="mt-6 pt-6 border-t border-white/10 space-y-4 text-emerald-100/70 text-sm">
            <p class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" class="text-emerald-400"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              Lumpyngngad, Shillong, Meghalaya (Approachable via Motinagar Road)
            </p>
            <p class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" class="text-emerald-400"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Response within 24 hours
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>