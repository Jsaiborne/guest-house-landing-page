---
---

<header id="main-header" class="fixed top-0 left-0 w-full z-40 transition-all duration-300 py-6 px-6 md:px-12 text-white">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <!-- Logo -->
    <a href="/" class="font-serif text-2xl md:text-3xl tracking-wide hover:text-emerald-300 transition-colors">
      Romillie Hadeljo
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium tracking-wider uppercase">
      <a href="/" class="hover:text-emerald-300 transition-colors">Home</a>
      <a href="/rooms" class="hover:text-emerald-300 transition-colors">Rooms</a>
      <a href="/faq" class="hover:text-emerald-300 transition-colors">FAQ</a>
      <a href="/rules" class="hover:text-emerald-300 transition-colors">Rules</a>
      <a 
        href="/#contact" 
        class="bg-white text-emerald-950 hover:bg-emerald-50 px-6 py-2.5 rounded-sm transition-all duration-300 shadow-md font-semibold tracking-widest text-xs"
      >
        Enquire Now
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button 
      id="menu-toggle" 
      class="md:hidden p-2 text-white hover:text-emerald-300 focus:outline-none transition-colors"
      aria-label="Toggle Menu"
    >
      <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
      <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Drawer Menu -->
  <div 
    id="mobile-menu" 
    class="hidden absolute top-full left-0 w-full bg-emerald-950/98 backdrop-blur-lg border-b border-white/10 flex flex-col items-center py-8 gap-6 shadow-xl"
  >
    <a href="/" class="mobile-link text-lg hover:text-emerald-300 transition-colors">Home</a>
    <a href="/rooms" class="mobile-link text-lg hover:text-emerald-300 transition-colors">Rooms</a>
    <a href="/faq" class="mobile-link text-lg hover:text-emerald-300 transition-colors">FAQ</a>
    <a href="/rules" class="mobile-link text-lg hover:text-emerald-300 transition-colors">Rules</a>
    <a 
      href="/#contact" 
      class="mobile-link bg-white text-emerald-950 px-8 py-3 rounded-sm font-semibold tracking-wider text-sm shadow-md hover:bg-emerald-50 transition-colors mt-2"
    >
      Enquire Now
    </a>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  // Backdrop effect on scroll
  const handleScroll = () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-emerald-950/80', 'backdrop-blur-md', 'shadow-lg', 'border-b', 'border-white/5', 'py-4');
      header?.classList.remove('py-6');
    } else {
      header?.classList.remove('bg-emerald-950/80', 'backdrop-blur-md', 'shadow-lg', 'border-b', 'border-white/5', 'py-4');
      header?.classList.add('py-6');
    }
  };

  window.addEventListener('scroll', handleScroll);
  // Trigger once on load in case of loaded scroll
  handleScroll();

  // Mobile menu toggle
  const toggleMenu = () => {
    const isExpanded = mobileMenu?.classList.contains('hidden');
    if (isExpanded) {
      mobileMenu?.classList.remove('hidden');
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      // Apply active style to header when menu is open
      header?.classList.add('bg-emerald-950');
    } else {
      mobileMenu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      if (window.scrollY <= 50) {
        header?.classList.remove('bg-emerald-950');
      }
    }
  };

  menuToggle?.addEventListener('click', toggleMenu);

  // Close menu when a link is clicked
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      if (window.scrollY <= 50) {
        header?.classList.remove('bg-emerald-950');
      }
    });
  });
</script>
