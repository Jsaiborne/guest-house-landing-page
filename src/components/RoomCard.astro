---
import { type Room } from '../data/rooms';

interface Props {
  room: Room;
}

const { room } = Astro.props;
---

<a 
  href={`/rooms/${room.slug}`} 
  class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-2 border border-stone-100"
>
  <div class="relative h-64 overflow-hidden">
    <img 
      src={room.images[0]} 
      alt={room.name} 
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    <div class="absolute bottom-4 left-4 text-white opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
      <span class="text-sm font-medium tracking-wider uppercase">View Details</span>
    </div>
  </div>
  
  <div class="p-6">
    <div class="flex justify-between items-start mb-2">
      <h3 class="text-2xl font-serif text-slate-900">{room.name}</h3>
      <span class="text-emerald-700 font-semibold">{room.price}<span class="text-xs text-slate-400 font-normal"> / night</span></span>
    </div>
    <p class="text-slate-500 text-sm leading-relaxed mb-4">
      {room.shortDescription}
    </p>
    
    <div class="flex flex-wrap gap-2">
      {room.amenities.slice(0, 3).map((amenity) => (
        <span class="text-[10px] uppercase tracking-wider bg-stone-100 text-stone-600 px-2 py-1 rounded-sm">
          {amenity}
        </span>
      ))}
      {room.amenities.length > 3 && (
        <span class="text-[10px] uppercase tracking-wider bg-stone-100 text-stone-600 px-2 py-1 rounded-sm">
          +{room.amenities.length - 3} more
        </span>
      )}
    </div>
  </div>
</a>