---
import { Wifi, Coffee, Car, Wind } from 'lucide-react';
---
<section class="py-20 bg-gray-50 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-12">Everything You Need</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="flex flex-col items-center">
        <Wifi className="w-10 h-10 mb-4 text-gray-600" />
        <span class="font-medium">High-Speed Wi-Fi</span>
      </div>
      <div class="flex flex-col items-center">
        <Coffee className="w-10 h-10 mb-4 text-gray-600" />
        <span class="font-medium">Breakfast Included</span>
      </div>
      <div class="flex flex-col items-center">
        <Car className="w-10 h-10 mb-4 text-gray-600" />
        <span class="font-medium">Free Parking</span>
      </div>
      <div class="flex flex-col items-center">
        <Wind className="w-10 h-10 mb-4 text-gray-600" />
        <span class="font-medium">AC & Heating</span>
      </div>
    </div>
  </div>
</section>