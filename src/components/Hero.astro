---
import fs from 'node:fs';
import path from 'node:path';

const heroDir = path.join(process.cwd(), 'public/images/hero');
const files = fs.existsSync(heroDir) ? fs.readdirSync(heroDir) : [];

const heroImages = files
  .filter((file: string) => /\.(jpe?g|png|gif|webp)$/i.test(file))
  .map((file: string) => `/images/hero/${file}`);
---

<section class="relative h-screen flex items-center justify-center overflow-hidden">
  <div id="hero-image-carousel" class="absolute inset-0 w-full h-full">
    {heroImages.length > 0 && (
      <img 
        src={heroImages[0]} 
        alt="Hero Image 1" 
        class="hero-image active" 
        loading="eager"
        fetchpriority="high"
      />
    )}
  </div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/80"></div>

  <style is:global>
    #hero-image-carousel .hero-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 1.5s ease-in-out;
    }
    #hero-image-carousel .hero-image.active {
      opacity: 1;
    }
  </style>

  <script define:vars={{ images: heroImages }}>
    let currentIndex = 1; // Start at 1 since 0 is pre-rendered
    const carouselDiv = document.getElementById('hero-image-carousel');

    function rotateImage() {
      if (!carouselDiv || images.length <= 1) return;

      const nextSrc = images[currentIndex];
      const nextImg = new Image();
      nextImg.src = nextSrc;

      nextImg.onload = () => {
        const previousImage = carouselDiv.querySelector('.hero-image.active');
        
        const newImage = document.createElement('img');
        newImage.src = nextSrc;
        newImage.alt = `Hero Image ${currentIndex + 1}`;
        newImage.classList.add('hero-image');
        carouselDiv.appendChild(newImage);

        // Force reflow
        void newImage.offsetWidth;
        newImage.classList.add('active');

        if (previousImage) {
          previousImage.classList.remove('active');
          previousImage.addEventListener('transitionend', () => {
            previousImage.remove();
          }, { once: true });

          // Fallback in case transitionend doesn't fire (e.g. background tab)
          setTimeout(() => {
            if (previousImage.parentNode) {
              previousImage.remove();
            }
          }, 2000);
        }

        currentIndex = (currentIndex + 1) % images.length;
        setTimeout(rotateImage, 5000); // Change image 5 seconds after current is ready
      };

      nextImg.onerror = () => {
        // Skip bad image
        currentIndex = (currentIndex + 1) % images.length;
        setTimeout(rotateImage, 1000);
      };
    }

    // Start carousel only if there is more than 1 image
    if (images.length > 1) {
      setTimeout(rotateImage, 5000);
    }
  </script>
  
  <div class="relative z-10 text-center px-4 mt-16">
    <span class="text-emerald-300 tracking-[0.3em] uppercase text-sm font-semibold mb-4 block">Welcome to</span>
    <h1 class="text-6xl md:text-8xl font-serif text-white mb-6 drop-shadow-lg">Romillie Hadeljo</h1>
    <p class="text-lg md:text-xl text-stone-200 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
      A serene getaway in the heart of Shillong. Experience comfort, tranquility, and unmatched hospitality.
    </p>
    <div class="flex flex-col items-center gap-6">
      <a 
        href="/rooms" 
        class="inline-block bg-white text-emerald-950 px-8 py-4 rounded-sm font-medium tracking-wide hover:bg-emerald-50 hover:-translate-y-1 transition-all duration-300 shadow-xl"
      >
        Explore Our Spaces
      </a>
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a 
          href="https://www.makemytrip.com/hotels/romillie_hadeljo-details-shillong.html" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-[#d9222a] text-white px-6 py-3 rounded-sm text-sm font-semibold tracking-wider uppercase hover:bg-[#bc1c22] hover:-translate-y-0.5 transition-all duration-300 shadow-md flex items-center justify-center gap-2"
        >
          Book on MakeMyTrip
        </a>
        <a 
          href="https://www.goibibo.com/hotels/romillie-hadeljo-hotel-in-shillong-4032960575066252791/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-[#f05a22] text-white px-6 py-3 rounded-sm text-sm font-semibold tracking-wider uppercase hover:bg-[#d64e1c] hover:-translate-y-0.5 transition-all duration-300 shadow-md flex items-center justify-center gap-2"
        >
          Book on Goibibo
        </a>
      </div>
    </div>
  </div>
</section>
